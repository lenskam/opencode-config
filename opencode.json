{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "n8n-mcp": {
      "type": "local",
      "enabled": true,
      "command": [
        "npx",
        "n8n-mcp"
      ],
      "environment": {
        "MCP_MODE": "stdio",
        "LOG_LEVEL": "error",
        "DISABLE_CONSOLE_OUTPUT": "true",
        "N8N_API_URL": "${env:N8N_API_URL}",
        "N8N_API_KEY": "${env:N8N_API_KEY}"
      }
    },
    "github": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${env:GITHUB_PAT_TOKEN}"
      },
      "enabled": true
    },
    "stitch": {
      "type": "remote",
      "enabled": true,
      "url": "https://stitch.googleapis.com/mcp",
      "headers": {
        "X-Goog-Api-Key": "${env:GOOGLE_MCP_API_KEY}"
      }
    },
    "mcp-image-gen": {
      "enabled": true,
      "type": "local",
      "command": [
        "node",
        "./mcp-servers/mcp-image-gen/dist/index.js"
      ],
      "environment": {
        "GEMINI_API_KEY": "${env:GEMINI_API_KEY}"
      }
    },
    "API specification": {
      "command": [
        "npx",
        "-y",
        "apidog-mcp-server@latest",
        "--oas=<oas-url-or-path>"
      ],
      "type": "local",
      "enabled": true
    },
    "sequential-thinking": {
      "enabled": true,
      "type": "local",
      "command": [
        "node",
        "./mcp-servers/servers/src/sequentialthinking/dist/index.js"
      ]
    },
    "wordpress": {
      "command": [
        "npx",
        "@automattic/mcp-wordpress-remote"
      ],
      "environment": {
        "WP_API_URL": "${env:WP_API_URL}",
        "WP_API_USERNAME": "${env:WP_API_USERNAME}",
        "WP_API_PASSWORD": "${env:WP_API_PASSWORD}"
      },
      "enabled": true,
      "type": "local"
    },
    "pencil": {
      "command": [
        "/home/kamdemlens/.antigravity/extensions/highagency.pencildev-0.6.36-universal/out/mcp-server-linux-x64",
        "--app",
        "antigravity"
      ],
      "enabled": true,
      "type": "local"
    }
  }
}