# === OpenCode Required Environment Variables ===
# Copy this to .env and fill in your values

# GitHub (for GitHub MCP server)
GITHUB_PAT_TOKEN=ghp_your_token_here

# n8n MCP
N8N_API_KEY=your_n8n_api_key
N8N_API_URL=https://n8n.yourdomain.cloud

# Gemini (for mcp-image-gen)
GEMINI_API_KEY=your_gemini_api_key

# Google MCP (for Stitch)
GOOGLE_MCP_API_KEY=your_google_api_key

# WordPress
WP_API_URL=https://your-wordpress-site.com
WP_API_USERNAME=your_username
WP_API_PASSWORD=your_password
